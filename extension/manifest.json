{
  "manifest_version": 3,
  "name": "SavClip - Social Downloader",
  "version": "1.0.0",
  "description": "Download videos from Instagram, TikTok, YouTube, and more with one click.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*",
    "*://*.youtube.com/*",
    "*://*.snapchat.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.facebook.com/*",
        "*://*.youtube.com/*",
        "*://*.snapchat.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": ["scripts/content.js"],
      "css": ["styles/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
